# Instalar pacotes (rodar apenas uma vez)
install.packages('remotes')
install.packages('tidyverse')
#Chamar pacote
library(remotes)
library(tidyverse)

#Instalar o  microdatasus
remotes::install_github("rfsaldanha/microdatasus")

#Liberar microdatasus
library(microdatasus)

#Baixar dados
sinan_dengue_sample <- fetch_datasus(
  year_start = 2023, year_end = 2023,
  information_system = "SINAN-DENGUE"
)

#Mostrar as primeiras linhas
head(sinan_dengue_sample) 

#Filtrar a coluna de UF
unique_ufs = unique(sinan_dengue_sample$SG_UF_NOT)
print(unique_ufs)

#Filtrar para DF 
dengue_filtrado_DF <- sinan_dengue_sample %>%
  filter(SG_UF_NOT == "53")

#Visualizar primeiras linhas
head(dengue_filtrado_DF)

#Quantos casos de Dengue em 2023 no DF
nrow(dengue_filtrado_DF)


#Agrupando casos de Dengue por mês

  #Filtrando a coluna data
  
dengue_filtrado_DF$DT_NOTIFIC <- as.Date(dengue_filtrado_DF$DT_NOTIFIC, format = "%Y-%m-%d")

dengue_mensal <- dengue_filtrado_DF %>%
  mutate(mes = format(DT_NOTIFIC, "%Y-%m")) %>%
  group_by(mes) %>%
  summarise(casos = n()) %>%
  arrange(mes)

print(dengue_mensal)

#Gerando gráfico para demonstrar os casos por meses 

ggplot(dengue_mensal, aes(x = mes, y = casos, group = 1)) +
  geom_line(color = "steelblue", linewidth = 1) +
  geom_point(color = "darkred", size = 2) +
  labs(title = "Casos de Dengue por Mês no Distrito Federal (2023)",
       x = "Mês",
       y = "Número de Casos") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))


  
